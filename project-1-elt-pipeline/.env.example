# Copy this file to .env and fill in your values
# Never commit .env to version control

# Airflow UID (run: echo $UID on Linux/Mac, use 50000 on Windows)
AIRFLOW_UID=50000

# Data Warehouse
POSTGRES_DWH_USER=fraud_user
POSTGRES_DWH_PASSWORD=fraud_pass
POSTGRES_DWH_DB=fraud_db
POSTGRES_DWH_HOST=localhost
POSTGRES_DWH_PORT=5433

# dbt (used for local dbt runs outside Docker)
DBT_POSTGRES_HOST=localhost
DBT_POSTGRES_PORT=5433
DBT_POSTGRES_USER=fraud_user
DBT_POSTGRES_PASSWORD=fraud_pass

# Path to raw CSV (used by ingestion script)
DATA_PATH=../data/creditcard.csv
